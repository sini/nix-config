#!/usr/bin/env bash
# ^ added for shellcheck and file-type detection

if [[ $(type -t use_flake) != function ]]; then
	echo "ERROR: use_flake function missing."
	echo "Please update direnv to v2.30.0 or later."
	exit 1
fi
if ! has nix_direnv_version || ! nix_direnv_version 3.0.6; then
  source_url "https://raw.githubusercontent.com/nix-community/nix-direnv/3.0.6/direnvrc" "sha256-RYcUJaRMf8oF5LznDrlCXbkOQrywm0HDv1VjYGaJGdM="
fi
# Lix uses "pipe-operator", Nix uses "pipe-operators" — detect and pass the right one
if nix --version 2>/dev/null | grep -q "Lix"; then
  PIPE_FLAG="pipe-operator"
else
  PIPE_FLAG="pipe-operators"
fi
use flake . --accept-flake-config --impure --extra-experimental-features "$PIPE_FLAG"
